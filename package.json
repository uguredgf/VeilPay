{
  "name": "veilpay-midnight",
  "version": "1.0.0",
  "description": "VeilPay - Privacy-preserving enterprise payroll on Midnight Network",
  "private": true,
  "workspaces": [
    "contract",
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build": "npm run build --workspace veilpay-backend --workspace veilpay-frontend",
    "start": "npm run start --workspace veilpay-backend",
    "test": "npm run test --workspace veilpay-backend"
  },
  "keywords": [
    "midnight",
    "privacy",
    "payroll",
    "zk-snarks",
    "compact",
    "blockchain",
    "night-sky-accelerator"
  ],
  "author": "VeilPay Team",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
