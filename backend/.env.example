PORT=3001
HOST=127.0.0.1
NODE_ENV=development

CORS_ORIGINS=http://localhost:3000,http://localhost:5173

DATABASE_PATH=./data/veilpay.db
CLAIM_ENCRYPTION_SECRET=replace-with-a-32-byte-secret
MAX_PAYROLL_ROWS=1000
MAX_PAYMENT_AMOUNT=1000000

MIDNIGHT_NETWORK=testnet
MIDNIGHT_INDEXER_URL=simulation://indexer
MIDNIGHT_NODE_URL=simulation://node
MIDNIGHT_PROOF_SERVER_URL=simulation://proof-server
MIDNIGHT_EXECUTION_MODE=simulation

COMPLIANCE_THRESHOLD=10000

LOG_FORMAT=dev
